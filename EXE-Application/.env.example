# ObserveProctor EXE Application Configuration
# Copy this file to .env and fill in your actual values

# Backend Server Configuration
OBSERVE_SERVER_URL=https://your-backend-url.cloudspaces.litng.ai

# Security: Request Signing Secret (must match server-side)
# Minimum 24 characters, mix of letters, numbers, and special characters
OBSERVE_PROCTOR_SECRET=your_secure_signing_secret_min_24_chars

# Blacklisted Process Hashes (SHA-256, comma-separated)
# Used to block suspicious processes during exam
OBSERVE_BLACKLISTED_SHA256=hash1,hash2,hash3

# Optional: Custom Code Execution Route (if backend uses non-default path)
# OBSERVE_CODE_RUN_PATH=/v1/exam/coding/run

# Optional: Additional URLs to Whitelist During Network Isolation (comma-separated)
OBSERVE_ADDITIONAL_WHITELIST_URLS=https://your-backend-url.cloudspaces,https://your-secondary-url.cloudspaces

# Optional: TLS Certificate Pinning (SHA-256 hex)
# OBSERVE_TLS_PIN_SHA256=your_certificate_pin_hash

# Firewall & Lockdown Settings
OBSERVE_ENABLE_FIREWALL_ISOLATION=1
OBSERVE_ENABLE_KEYBOARD_LOCKDOWN=1
OBSERVE_REQUIRE_KEYBOARD_LOCKDOWN=1
OBSERVE_STRICT_OS_LOCKDOWN=1
OBSERVE_LOCKDOWN_BLOCK_INPUT=1
OBSERVE_STRICT_TOUCHPAD_LOCKDOWN=1

# Auto-Termination Configuration
OBSERVE_ENABLE_RUNTIME_AUTO_TERMINATE=1
OBSERVE_RUNTIME_AUTO_TERMINATE_COOLDOWN_SEC=3
OBSERVE_RUNTIME_AUTO_TERMINATE_MAX_PER_SCAN=10

# Full Lockdown Settings
OBSERVE_ENABLE_FULL_LOCKDOWN=1
OBSERVE_FULL_LOCKDOWN_SCAN_INTERVAL_SEC=1.5

# Exam Window Management
OBSERVE_FORCE_EXAM_TOPMOST=1
OBSERVE_FOCUS_GUARD_INTERVAL_MS=1200

