# ObserveProctor EXE Application Configuration
# Copy this file to .env and fill in your actual values

# Backend Server Configuration
VIRTUSA_SERVER_URL=https://your-backend-url.cloudspaces.litng.ai

# Security: Request Signing Secret (must match server-side)
# Minimum 24 characters, mix of letters, numbers, and special characters
VIRTUSA_PROCTOR_SECRET=your_secure_signing_secret_min_24_chars

# Blacklisted Process Hashes (SHA-256, comma-separated)
# Used to block suspicious processes during exam
VIRTUSA_BLACKLISTED_SHA256=hash1,hash2,hash3

# Optional: Custom Code Execution Route (if backend uses non-default path)
# VIRTUSA_CODE_RUN_PATH=/v1/exam/coding/run

# Optional: Additional URLs to Whitelist During Network Isolation (comma-separated)
VIRTUSA_ADDITIONAL_WHITELIST_URLS=https://your-backend-url.cloudspaces,https://your-secondary-url.cloudspaces

# Optional: TLS Certificate Pinning (SHA-256 hex)
# VIRTUSA_TLS_PIN_SHA256=your_certificate_pin_hash

# Firewall & Lockdown Settings
VIRTUSA_ENABLE_FIREWALL_ISOLATION=1
VIRTUSA_ENABLE_KEYBOARD_LOCKDOWN=1
VIRTUSA_REQUIRE_KEYBOARD_LOCKDOWN=1
VIRTUSA_STRICT_OS_LOCKDOWN=1
VIRTUSA_LOCKDOWN_BLOCK_INPUT=1
VIRTUSA_STRICT_TOUCHPAD_LOCKDOWN=1

# Auto-Termination Configuration
VIRTUSA_ENABLE_RUNTIME_AUTO_TERMINATE=1
VIRTUSA_RUNTIME_AUTO_TERMINATE_COOLDOWN_SEC=3
VIRTUSA_RUNTIME_AUTO_TERMINATE_MAX_PER_SCAN=10

# Full Lockdown Settings
VIRTUSA_ENABLE_FULL_LOCKDOWN=1
VIRTUSA_FULL_LOCKDOWN_SCAN_INTERVAL_SEC=1.5

# Exam Window Management
VIRTUSA_FORCE_EXAM_TOPMOST=1
VIRTUSA_FOCUS_GUARD_INTERVAL_MS=1200
