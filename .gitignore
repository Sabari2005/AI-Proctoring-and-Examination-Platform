# -----------------------------------------------------------------------------
# Workspace-wide Git ignore policy
# Covers: Python services, Vite frontend, Docker workflows, Windows EXE app
# -----------------------------------------------------------------------------

# ---- Secrets and local environment ----
.env
.env.*
!.env.example
!.env.sample
!.env.template
**/.env
**/.env.*
!**/.env.example
!**/.env.sample
!**/.env.template

# ---- Python caches and virtual environments ----
__pycache__/
**/__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
**/.pytest_cache/
.mypy_cache/
**/.mypy_cache/
.ruff_cache/
**/.ruff_cache/
.hypothesis/
.tox/
.nox/
.venv/
venv/
env/

# ---- Python build/test/coverage artifacts ----
.coverage
.coverage.*
htmlcov/
.pyre/
.dmypy.json

# ---- Node / frontend artifacts ----
node_modules/
**/node_modules/
dist/
**/dist/
dist-ssr/
coverage/
*.tsbuildinfo
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ---- Runtime logs and temp files ----
logs/
**/logs/
*.log
*.pid
*.seed
*.out
*.err

# ---- Editor and OS files ----
.vscode/*
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp
*.swo
.DS_Store
Thumbs.db

# ---- EXE-Application specific generated outputs ----
EXE-Application/dist/
EXE-Application/build/
EXE-Application/build_log.txt
EXE-Application/server/log.txt
EXE-Application/server/evidence_frames/
EXE-Application/logs/

# ---- General local databases / artifacts ----
*.sqlite3
*.db
