# Coding Environment Service Configuration
# Copy this file to .env and fill in your actual values

# Environment Mode
ENVIRONMENT=production

# Security
SECRET_KEY=your-32-character-hex-secret-key-here-minimum-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# CORS & Allowed Origins
ALLOWED_ORIGINS=["http://localhost","https://your-domain.com"]
ALLOWED_HOSTS=["localhost","127.0.0.1","your-domain.com"]

# Database Configuration
POSTGRES_DB=proctordb
POSTGRES_USER=your_postgres_user
POSTGRES_PASSWORD=your_postgres_password_here
DATABASE_URL=postgresql://username:password@host.neon.tech/dbname?sslmode=require&channel_binding=require
DATABASE_SYNC_URL=postgresql://username:password@host.neon.tech/dbname?sslmode=require&channel_binding=require

# Redis Configuration
REDIS_PASSWORD=your_redis_password_here
REDIS_URL=redis://:your_redis_password_here@redis:6379/0
CELERY_BROKER_URL=redis://:your_redis_password_here@redis:6379/1
CELERY_RESULT_BACKEND=redis://:your_redis_password_here@redis:6379/2

# Execution Limits
MAX_EXECUTION_TIME_SECONDS=10
MAX_MEMORY_MB=256
MAX_OUTPUT_BYTES=65536
MAX_CONCURRENT_EXECUTIONS=50
EXECUTION_TIMEOUT_BUFFER_SECONDS=2

# Docker Sandbox
DOCKER_NETWORK=none
SANDBOX_IMAGE_PREFIX=proctor-sandbox

# S3 Storage (Optional)
LOG_TO_S3=false
S3_BUCKET=
AWS_REGION=us-east-1

# Rate Limiting
RATE_LIMIT_SUBMISSIONS_PER_MINUTE=5
RATE_LIMIT_REQUESTS_PER_MINUTE=100

# Internal Secret
VIRTUSA_INTERNAL_SECRET=your_internal_secret_here
