# JIT Generator Service Configuration
# Copy this file to .env and fill in your actual values

# LLM API Keys
GROQ_API_KEY=gsk_your_groq_api_key_here
GEMINI_API_KEY=AIza_your_google_gemini_key_here

# LangSmith Tracing (Optional)
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=lsv2_your_langsmith_api_key_here
LANGCHAIN_PROJECT=llm-question-morphing

# App Configuration
MAX_RETRIES=3
DEFAULT_MODEL=llama-3.3-70b-versatile
FALLBACK_MODEL=gemini-2.5-flash
MIN_SEMANTIC_SCORE=0.82

# Database Configuration (Optional for server mode)
DATABASE_URL=postgresql://username:password@host.neon.tech/dbname?sslmode=require&channel_binding=require
